Package: PACE
Type: Package
Title: Proximity-Associated Changes in Expression for Spatial Transcriptomics
Version: 0.99.0
Authors@R: c(
    person("Elijah", "Willie", email = "ewillie0004@gmail.com",
           role = c("aut", "cre")),
